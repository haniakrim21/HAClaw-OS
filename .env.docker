# ClawdOS Docker Configuration
# Copy to .env and fill in values:  cp .env.docker .env

# Database (change in production!)
POSTGRES_PASSWORD=clawdos

# App
APP_URL=http://localhost:3000
PORT=3000
SESSION_PASSWORD=change_me_to_a_long_random_string_at_least_32_chars

# Default user (created on first run if no users exist)
CLAWDOS_USER=admin
CLAWDOS_PASSWORD=changeme123

# Shared auth token between ClawdOS and OpenClaw
CLAWDBOT_TOKEN=change_me_generate_with_openssl_rand_hex_24
CLAWDOS_CONSULT_TOKEN=change_me_generate_with_openssl_rand_hex_24

# OpenClaw — AI model provider (at least one required for AI chat)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# Timezone
TZ=Asia/Riyadh

# Access gate (optional — protects UI with a token)
# ACCESS_TOKEN=
